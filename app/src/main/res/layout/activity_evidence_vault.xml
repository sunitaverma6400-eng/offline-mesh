<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PIN gate -->
    <LinearLayout
        android:id="@+id/pinScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:id="@+id/textVaultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 Evidence Vault"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/textVaultInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#666666"
            android:paddingBottom="16dp"
            android:text="Chat se bilkul alag, apni encrypted gallery — apna Access PIN, apna Duress PIN, apna Wipe." />

        <EditText
            android:id="@+id/editVaultPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vault PIN"
            android:inputType="numberPassword" />

        <Button
            android:id="@+id/buttonUnlockVault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Unlock" />

    </LinearLayout>

    <!-- Unlocked vault -->
    <LinearLayout
        android:id="@+id/vaultScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="8dp">

        <TextView
            android:id="@+id/textNamespaceLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:paddingBottom="4dp" />

        <GridView
            android:id="@+id/gridEvidence"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:numColumns="3"
            android:horizontalSpacing="4dp"
            android:verticalSpacing="4dp"
            android:stretchMode="columnWidth" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonCapturePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷 Capture photo" />

                <Button
                    android:id="@+id/buttonCaptureVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎥 Capture video" />

                <Button
                    android:id="@+id/buttonImportEvidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖼 Import" />

                <Button
                    android:id="@+id/buttonVaultSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙ Duress PIN" />

                <Button
                    android:id="@+id/buttonLockVault"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒 Lock" />

                <Button
                    android:id="@+id/buttonWipeVault"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wipe Vault"
                    android:textColor="#B00020" />

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

</FrameLayout>
